.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# OS/editor
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
.venv-*/
.cache/
*.egg-info/
