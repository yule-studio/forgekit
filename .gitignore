# Local agent runtime/state
.claude/plans/
.claude/settings.local.json
.claude/*.lock
.codex/
# Gemini CLI: ignore local state, but TRACK the generated command projection
# (.gemini/commands/ is a sync_harness_skills.py artifact, like .claude/skills/).
.gemini/*
!.gemini/commands/
runs/*
!runs/.gitkeep
# forgekit-console runtime output: the daemon/autopilot mutator writes safe-class
# notes under <repo_root>/runs/ when repo_root resolves to the app dir (#241/#240).
# That is runtime churn — never commit it (committed evidence lives in examples/).
apps/forgekit-console/runs/

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# OS/editor
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
.venv-*/
.cache/
*.egg-info/
