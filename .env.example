# Engineering Agent Discord channels
# intake 채널만 런타임에서 직접 읽습니다. approval/status/lab은 후속 운영 UX 예약 슬롯입니다.
# DISCORD_ENGINEERING_INTAKE_CHANNEL_ID=
# DISCORD_ENGINEERING_INTAKE_CHANNEL_NAME=업무-접수
# DISCORD_ENGINEERING_APPROVAL_CHANNEL_ID=
# DISCORD_ENGINEERING_APPROVAL_CHANNEL_NAME=승인-대기
# DISCORD_ENGINEERING_STATUS_CHANNEL_ID=
# DISCORD_ENGINEERING_STATUS_CHANNEL_NAME=봇-상태
# DISCORD_ENGINEERING_LAB_CHANNEL_ID=
# DISCORD_ENGINEERING_LAB_CHANNEL_NAME=실험실

# Cross-agent research forum (engineering 외 부서도 공유하는 inbox — Forum 채널 권장)
# 자세한 운영 규약: policies/runtime/agents/engineering-agent/research-forum.md
# 운영 길드의 운영-리서치 forum 채널 ID 예시: 1499287359483805879
# DISCORD_AGENT_RESEARCH_FORUM_CHANNEL_ID=
# DISCORD_AGENT_RESEARCH_FORUM_CHANNEL_NAME=운영-리서치

# Engineering Agent member bots (Phase 2 — leave blank to keep single-bot mode)
# ENGINEERING_AGENT_BOT_GATEWAY_TOKEN=
# ENGINEERING_AGENT_BOT_TECH_LEAD_TOKEN=
# ENGINEERING_AGENT_BOT_AI_ENGINEER_TOKEN=
# ENGINEERING_AGENT_BOT_PRODUCT_DESIGNER_TOKEN=
# ENGINEERING_AGENT_BOT_BACKEND_ENGINEER_TOKEN=
# ENGINEERING_AGENT_BOT_FRONTEND_ENGINEER_TOKEN=
# ENGINEERING_AGENT_BOT_QA_ENGINEER_TOKEN=
# ENGINEERING_AGENT_BOT_DEVOPS_ENGINEER_TOKEN=

# Reference sources (slot reservation only — not wired in MVP)
# REFERENCE_PINTEREST_BUSINESS_ACCESS_TOKEN=
# REFERENCE_META_AD_LIBRARY_ACCESS_TOKEN=
# REFERENCE_TIKTOK_CREATIVE_CENTER_ACCESS_TOKEN=
# REFERENCE_GOOGLE_TRENDS_API_KEY=

# Autonomous research collector (사용자에게 자료 묻기 전 1차 수집)
# 자세한 운영 규약: policies/runtime/agents/engineering-agent/research-collector.md
# enabled=false면 NoOpCollector → 사용자 자료가 있으면 그대로 사용, 없으면 사용자에게 요청.
# provider 옵션:
#   - mock(기본): 외부 네트워크 없이 결정적으로 동작 (CI/dev 디폴트).
#   - tavily / brave: 해당 API key가 있을 때만 활성, 없으면 silent fallback.
#   - auto / multi: 역할별 정책에 따라 Tavily + Brave를 함께 호출 (둘 중 하나만 키가 있으면 그쪽만 사용).
# ENGINEERING_RESEARCH_PROVIDERS는 auto 모드에서만 사용; 비워 두면 (tavily,brave)가 기본.
# ENGINEERING_RESEARCH_MAX_PROVIDER_CALLS는 auto 모드에서 모든 provider 호출의 합계 상한이다 — 비용 안전장치이므로 낮게 시작하길 권장.
# ENGINEERING_RESEARCH_AUTO_COLLECT_ENABLED=false
# ENGINEERING_RESEARCH_PROVIDER=mock
# ENGINEERING_RESEARCH_PROVIDERS=tavily,brave
# ENGINEERING_RESEARCH_MAX_RESULTS=5
# ENGINEERING_RESEARCH_MAX_PROVIDER_CALLS=3
# ENGINEERING_RESEARCH_MAX_RESULTS_PER_ROLE=2
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=

# 운영-리서치 포럼 코멘트 게시 모드 (member-bots | gateway)
# member-bots(기본): 게이트웨이는 포스트 생성과 첫 [research-turn:...] 디렉티브만 남기고,
#                    각 멤버 봇이 자기 역할 차례에 자기 계정으로 의견을 남긴다 (실제 팀 회의 느낌).
# gateway: 게이트웨이가 모든 역할 코멘트를 대신 게시 (멤버 봇 토큰이 없을 때 폴백).
# ENGINEERING_RESEARCH_FORUM_COMMENT_MODE=member-bots

# Obsidian local sync (`yule obsidian sync`)
# Obsidian vault의 절대경로. 이 값이 있어야 ResearchPack을 실제 Markdown 파일로 저장한다.
# 실제 사용자 절대경로는 .env.local에 둬라 — .env.example은 git에 커밋되므로 placeholder만 둔다.
# 예: OBSIDIAN_VAULT_PATH=/Users/<MY_USER>/local-dev/yule-agent-vault/obsidian-vault
# OBSIDIAN_VAULT_PATH=
#
# Obsidian export 레이아웃 (yule-agent-vault | legacy-agent)
#  - yule-agent-vault(기본): 결과를 10-projects/<project>/<kind>/ 아래에 저장.
#    프로젝트 미지정 시 OBSIDIAN_DEFAULT_PROJECT(없으면 yule-studio-agent)에 들어간다.
#    알 수 없는 kind는 00-inbox/unsorted/로 라우팅되어 triage 큐로 노출된다.
#  - legacy-agent: 옛 Agents/Engineering/<Research|Decisions|References>/ 트리에 저장.
#    이미 마이그레이션 안 된 vault에서만 사용. CLI에서는 `--layout legacy-agent`.
# OBSIDIAN_EXPORT_LAYOUT=yule-agent-vault
# OBSIDIAN_DEFAULT_PROJECT=yule-studio-agent
