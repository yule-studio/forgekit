# YULE_WORK_END_TIME=18:00
# YULE_COMMUTE_MINUTES=45
# YULE_DEPARTURE_BUFFER_MINUTES=10
# YULE_HOME_AREA=신정동
# YULE_WORK_AREA=마곡
# YULE_WORK_MODE_ENABLED=true
# YULE_LUNCH_DURATION_MINUTES=60
# YULE_TIMEZONE=Asia/Seoul

