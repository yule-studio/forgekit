  "autonomy_level": "advisory",
  "risk_class": "MEDIUM",
  "can_write_code": false,
  "can_commit": false,
  "can_open_pr": false,
  "can_write_vault": true,
  "obsidian_write_target": "40-ops/ops-observer",
  "color_token": "eng-ops-observer",
  "capabilities": [
    "runtime_doctor_cadence",
    "budget_token_alerts",
    "fallback_spike_detection",
    "blocked_queue_health_summary",
    "operator_next_action_surface"
