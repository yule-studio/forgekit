{
  "id": "engineering-agent",
  "name": "Engineering Agent (Engineering Department)",
  "type": "department",
  "description": "Engineering department gateway under the future CTO organization. Receives requests from upstream agents (planning-agent, orchestrator, eventually cto-agent) and posts work for role members (tech-lead, ai-engineer, product-designer, backend-engineer, frontend-engineer, qa-engineer, devops-engineer). Members should behave like autonomous employees: inspect the work, gather role-specific context, propose or execute next steps within approval gates, and collaborate through Discord/GitHub artifacts.",
  "members": [
    "tech-lead",
    "ai-engineer",
    "product-designer",
    "backend-engineer",
    "frontend-engineer",
    "qa-engineer",
    "devops-engineer"
  ],
  "cross_cutting_reviewers": [
    "security-engineer"
  ],
  "cross_cutting_reviewers_note": "members 는 7-role deliberation council seat(role_profiles_data SSoT). cross_cutting_reviewers 는 council seat 가 아니라 특정 변경 유형에서 끼어드는 리뷰 게이트 — security-engineer 의 진입 조건/계약 SSoT 는 docs/security-review.md.",
  "execution_mode": "autonomous_member_team_with_approval_gates",
  "default_executor": "claude",
  "instruction_entry": "agents/engineering-agent/CLAUDE.md",
  "council_runtime": {
    "design_doc": "docs/engineering-role-council-runtime.md",
    "phase": "C1-scaffolding",
    "seat_model": {
      "default_seats": ["owner", "challenger", "reviewer"],
      "provider_seat_orthogonal": true,
      "council_round_cap": 2,
      "escalation_target": "tech-lead",
      "external_surface": "public_summary_only"
    },
    "approval_owners": {
      "technical_signoff": "tech-lead",
      "operator_approval_surface": "gateway"
    },
    "approval_statuses": [
      "draft",
      "ready",
      "conditional",
      "escalated",
      "archived"
    ],
    "deliverable_schemas": [
      "TaskBrief",
      "RoleWorkOrder",
      "RoleDraft",
      "PeerReviewNote",
      "RoleCouncilResult",
      "ApprovalPacket",
      "ExecutionReview",
      "RetrospectiveCandidate"
    ],
    "hard_rails": [
      "single_executor_per_run",
      "no_auto_policy_self_modification",
      "no_internal_deliberation_dump_to_discord",
      "secret_deploy_merge_remain_operator_approval"
    ]
  },
  "team_topology": {
    "phase": "mvp-4-core-teams",
    "core_execution_teams": [
      {
        "team_id": "forgekit-core-team",
        "purpose": "ForgeKit core domain과 operator workflow를 실제 실행 가능한 packet/approval 흐름으로 연결한다.",
        "lead_role": "tech-lead",
        "member_roles": [
          "tech-lead",
          "backend-engineer",
          "frontend-engineer",
          "product-designer"
        ],
        "owns": [
          "goal/runtime core handoff",
          "work packet / routing",
          "approval queue / operator workflow",
          "CLI/TUI coding surface"
        ],
        "expands_to": [
          "forgekit-core-division",
          "product-engineering-division"
        ]
      },
      {
        "team_id": "platform-runtime-team",
        "purpose": "24시간 scheduler/queue/provider/worktree/runtime health 를 안정적으로 굴리는 실행팀.",
        "lead_role": "platform-runtime-engineer",
        "member_roles": [
          "platform-runtime-engineer",
          "devops-engineer",
          "ops-observer"
        ],
        "owns": [
          "scheduler / job queue",
          "provider runtime / token-budget",
          "worktree isolation / daemon health",
          "runtime doctor / operator next-action"
        ],
        "expands_to": [
          "platform-runtime-division",
          "devex-internal-tools-division"
        ]
      },
      {
        "team_id": "skill-rnd-team",
        "purpose": "에이전트 지능, skill 도입 실험, memory/retrieval 품질을 높이는 R&D 실행팀.",
        "lead_role": "ai-engineer",
        "member_roles": [
          "ai-engineer",
          "knowledge-engineer"
        ],
        "owns": [
          "prompt / context-pack / model-routing",
          "skill / MCP / framework adoption review",
          "retrieval / canonical knowledge improvement",
          "evaluation-ready experiment notes"
        ],
        "expands_to": [
          "agent-ai-division",
          "skill-rnd-division",
          "data-knowledge-engineering-division"
        ]
      },
      {
        "team_id": "qa-governance-team",
        "purpose": "fake completion 을 막고 test·security·approval governance 를 코드로 묶는 검증팀.",
        "lead_role": "qa-engineer",
        "member_roles": [
          "qa-engineer",
          "security-engineer"
        ],
        "owns": [
          "regression / acceptance / e2e review",
          "reality-check / source-grounding",
          "issue / PR / git governance",
          "approval gate / audit trail"
        ],
        "expands_to": [
          "qa-evaluation-division",
          "security-governance-engineering-division"
        ]
      }
    ],
    "growth_path": {
      "mvp_4": [
        "forgekit-core-team",
        "platform-runtime-team",
        "skill-rnd-team",
        "qa-governance-team"
      ],
      "growth_8": [
        "forgekit-core-team",
        "platform-runtime-team",
        "agent-ai-team",
        "personal-repo-team",
        "skill-rnd-team",
        "revenue-product-lab",
        "knowledge-data-team",
        "qa-governance-team"
      ],
      "target_12": [
        "forgekit-core-division",
        "platform-runtime-division",
        "agent-ai-division",
        "product-engineering-division",
        "personal-repo-division",
        "skill-rnd-division",
        "revenue-product-lab",
        "data-knowledge-engineering-division",
        "security-governance-engineering-division",
        "qa-evaluation-division",
        "devex-internal-tools-division",
        "integration-automation-division"
      ]
    }
  },
  "policies": [
    "policies/runtime/common/safety.md",
    "policies/runtime/common/context-loading.md",
    "policies/runtime/agents/engineering-agent/team-structure.md",
    "policies/runtime/agents/engineering-agent/mvp-scope.md",
    "policies/runtime/agents/engineering-agent/role-profiles.md",
    "policies/runtime/agents/engineering-agent/role-weights-v0.md",
    "policies/runtime/agents/engineering-agent/runners.md",
    "policies/runtime/agents/engineering-agent/env-strategy.md",
    "policies/runtime/agents/engineering-agent/multi-bot-launcher.md",
    "policies/runtime/agents/engineering-agent/dispatcher.md",
    "policies/runtime/agents/engineering-agent/discord-workflow.md",
    "policies/runtime/agents/engineering-agent/message-protocol.md",
    "policies/runtime/agents/engineering-agent/version-control.md",
    "policies/runtime/agents/engineering-agent/workflow.md",
    "policies/runtime/agents/engineering-agent/testing.md",
    "policies/runtime/agents/engineering-agent/memory-policy.md",
    "policies/runtime/agents/engineering-agent/recall-policy.md",
    "policies/runtime/agents/engineering-agent/context-compression.md",
    "policies/runtime/agents/engineering-agent/self-improvement-flow.md",
    "policies/runtime/agents/engineering-agent/scheduled-automation.md"
  ],
  "write_policy": {
    "max_write_executors_per_run": 1,
    "require_user_approval_before_write": true,
    "allow_advisor_patch_proposals": true,
    "allow_parallel_writes": false,
    "require_human_review_before_publish": true
  },
  "participants": [
    {
      "id": "claude",
      "provider": "anthropic",
      "roles": ["executor", "planner"],
      "permissions": ["read", "propose", "write"],
      "allowed_tools": [
        "filesystem.read",
        "filesystem.write_after_approval",
        "git.status",
        "git.diff",
        "git.branch",
        "tests.run",
        "github.issue.read",
        "github.pull_request.prepare"
      ],
      "notes": "Primary coding partner for implementation work during the initial MVP."
    },
    {
      "id": "codex",
      "provider": "openai",
      "roles": ["advisor", "reviewer", "patch_proposer"],
      "permissions": ["read", "propose"],
      "allowed_tools": [
        "filesystem.read",
        "git.status",
        "git.diff",
        "tests.run",
        "github.issue.read"
      ],
      "notes": "Used for implementation review, patch suggestions, and test-focused feedback."
    },
    {
      "id": "gemini",
      "provider": "google",
      "roles": ["requirements_reviewer", "long_context_advisor", "planner"],
      "permissions": ["read", "propose"],
      "allowed_tools": [
        "filesystem.read",
        "git.status",
        "git.diff",
        "github.issue.read"
      ],
      "notes": "Used for long-context analysis, requirement review, and planning support."
    },
    {
      "id": "ollama",
      "provider": "local",
      "model": "gemma3:latest",
      "endpoint": "http://localhost:11434",
      "roles": ["local_private_assistant", "classifier", "summarizer"],
      "permissions": ["read", "propose"],
      "allowed_tools": [
        "filesystem.read",
        "git.diff"
      ],
      "notes": "Runs on the user's machine or home server for private local assistance."
    }
  ],
  "integrations": [
    {
      "id": "github-copilot",
      "provider": "github",
      "type": "github_workflow_assistant",
      "roles": ["github_native_executor"],
      "permissions": ["read", "propose"],
      "allowed_tools": [
        "github.issue.read",
        "github.pull_request.prepare"
      ],
      "notes": "Works through GitHub issue, branch, and pull request workflows rather than direct local execution."
    }
  ],
  "tool_catalog": [
    "filesystem.read",
    "filesystem.write_after_approval",
    "git.status",
    "git.diff",
    "git.branch",
    "tests.run",
    "github.issue.read",
    "github.issue.prepare",
    "github.pull_request.prepare"
  ]
}
