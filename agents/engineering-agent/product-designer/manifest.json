    ],
    "product-owner_or_user": [
      "사용자 흐름 변경 / MVP 범위 재조정 / 톤 결정"
    ]
  },
  "user_goal_standard": {
    "must_include": [
      "primary_user",
      "user_goal_in_one_sentence",
      "user_motivation",
      "out_of_scope_users"
    ],
    "rules": [
      "사용자 목표 한 줄이 없으면 화면 제안을 시작하지 않는다",
