    "/init": {"purpose": "CLAUDE.md/AGENTS.md 가이드 초기화", "harness": ["claude", "codex"], "interactive_only": false, "grantable": true},
    "/security-review": {"purpose": "보안 취약점 분석", "harness": ["claude"], "interactive_only": false, "grantable": true},
    "/diff": {"purpose": "변경 사항 확인", "harness": ["claude", "codex"], "interactive_only": false, "grantable": true},
