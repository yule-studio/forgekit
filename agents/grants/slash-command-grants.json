    "/permissions": {"purpose": "도구 권한 허용/거부 규칙", "harness": ["claude"], "interactive_only": true, "grantable": false},
    "/agents": {"purpose": "서브에이전트 관리 (대화형 UI)", "harness": ["claude"], "interactive_only": true, "grantable": false},
    "/plugin": {"purpose": "Claude Code 플러그인 관리 (대화형 UI)", "harness": ["claude"], "interactive_only": true, "grantable": false},
    "/mcp": {"purpose": "MCP 서버 연결/인증 (대화형 UI)", "harness": ["claude", "codex"], "interactive_only": true, "grantable": false}
